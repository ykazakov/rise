{
  "name": "jupyterlab-rise-application",
  "version": "0.43.1",
  "description": "Rise Application based on JupyterLab modules.",
  "private": true,
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/jupyterlab-contrib/rise",
  "bugs": {
    "url": "https://github.com/jupyterlab-contrib/rise/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Frederic Collonval"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/jupyterlab-contrib/rise.git"
  },
  "scripts": {
    "build": "tsc --sourceMap",
    "build:prod": "tsc -b",
    "build:test": "tsc --build tsconfig.test.json",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "tsc -b --watch --preserveWatchOutput --sourceMap"
  },
  "dependencies": {
    "@jupyter/collaboration-extension": "^2.0.0",
    "@jupyter/ydoc": "~3.4.1",
    "@jupyterlab/application": "~4.5.6",
    "@jupyterlab/apputils": "~4.5.6",
    "@jupyterlab/cells": "~4.5.6",
    "@jupyterlab/coreutils": "~6.5.6",
    "@jupyterlab/docmanager": "~4.5.6",
    "@jupyterlab/docregistry": "~4.5.6",
    "@jupyterlab/filebrowser": "~4.5.6",
    "@jupyterlab/fileeditor": "~4.5.6",
    "@jupyterlab/mathjax-extension": "~4.5.6",
    "@jupyterlab/notebook": "~4.5.6",
    "@jupyterlab/notebook-extension": "~4.5.6",
    "@jupyterlab/rendermime": "~4.5.6",
    "@jupyterlab/rendermime-interfaces": "~3.11.6",
    "@jupyterlab/services": "~7.5.6",
    "@jupyterlab/settingregistry": "~4.5.6",
    "@jupyterlab/statusbar": "~4.5.6",
    "@jupyterlab/theme-light-extension": "~4.5.6",
    "@jupyterlab/translation": "~4.5.6",
    "@jupyterlab/translation-extension": "~4.5.6",
    "@lumino/commands": "^2.0.0",
    "@lumino/messaging": "^2.0.0",
    "@lumino/signaling": "^2.0.0",
    "@lumino/widgets": "^2.0.0",
    "reveal.js": "^4.4.0",
    "reveal.js-plugins": "^4.1.5"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5.6",
    "@types/reveal.js": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "mkdirp": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.5.4"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "coreDependency": true
  }
}
